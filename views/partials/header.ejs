
<header id="top-header">
  <span class="siteName">
    <a href="/" title="Return to home page">CSE Motors</a>
  </span>
  <div id="tools" class="tools">
    <a title="Click to log in" href="/account/login" id="headerName"></a>

     <% if (locals.loggedin) { %>
    <!-- Use the properties you stored in the JWT payload -->
    <a href="/account"><span class="headName">Welcome, <%= accountData.account_firstname %>!</span></a>
    <form action="/account/logout" method="post">
      <button type="submit" class="outBut">Logout</button>
    </form>
    <!-- <a href="/account/logout">Logout</a> -->
  <% } else { %>
    <a href="/account/login">My Account.</a>
  <% } %>
  </div>


</header>

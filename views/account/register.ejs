


<% if (errors) { %>
  <ul class="notice">
 <% errors.array().forEach(error => { %>
   <li><%= error.msg %></li>
<%  }) %>
 </ul>
<% } %>


<% if (title) { %>
<h1 class="register"><%= title %></h1>
<% } else {
  res.redirect('/')
} %>


<!-- <h1 >REGISTER</h1> -->

 <div class="form">
    
        <form action="/account/register" method="post" class="registerForm">
          
                <div class="flex">
                    <p>Firstname*</p>
                <label><input type="text" name="account_firstname" title="account_firstname" autocomplete="given-name" required></label>
                <p>Lastname*</p>
                <label><input type="text" name="account_lastname" title="account_lastname" autocomplete="family-name" required></label>
                <p>Email*</p>
                <label><input type="email" name="account_email" title="account_email" autocomplete="email" required></label>
                <p>Password*</p>
                <span class="passRule">Passwords must be at least 12 characters and contain at least 1 number, 1 capital letter and 1 special character</span> <br>
                <label><input type="password" name="account_password" title="account_password" pattern="^(?=.*\d)(?=.*[a-z])(?=.*[A-Z])(?=.*[^a-zA-Z0-9])(?!.*\s).{12,}$" required></label>
                </div>
            
                <input type="submit" value="register" class="registerButton">
                
                </form>
            </div>